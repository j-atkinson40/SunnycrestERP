# ──────────────────────────────────────────────
# Bridgeable — Frontend Environment Variables
# Copy to .env and fill in values
# ──────────────────────────────────────────────

# Backend API URL (required)
VITE_API_URL=http://localhost:8000

# Application name (used in UI branding)
VITE_APP_NAME=Bridgeable

# Environment identifier (dev | staging | production)
VITE_ENVIRONMENT=dev

# Playwright incident reporter (test infrastructure — not used by the app)
# BACKEND_URL=https://sunnycresterp-staging.up.railway.app
# INTERNAL_API_KEY=<set in Railway or local env>
# TEST_ENV=staging
