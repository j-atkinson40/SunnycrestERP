# ──────────────────────────────────────────────
# Bridgeable — Backend Environment Variables
# Copy to .env and fill in values
# ──────────────────────────────────────────────

# Database (required)
DATABASE_URL=postgresql://localhost:5432/bridgeable_dev

# Auth (required)
SECRET_KEY=change-me-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (required)
CORS_ORIGINS=["http://localhost:5173"]
CORS_ORIGIN_REGEX=

# Environment identifier (dev | staging | production)
ENVIRONMENT=dev

# Redis (optional — job queue degrades to DB polling without it)
REDIS_URL=redis://localhost:6379

# AI (optional)
ANTHROPIC_API_KEY=

# Google Places (optional — funeral home directory discovery)
GOOGLE_PLACES_API_KEY=

# Stripe billing (optional — only needed if billing is configured)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# QuickBooks Online OAuth (optional — only needed if QBO integration is used)
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=

# Email via Resend (optional — falls back to console logging in dev)
# Set RESEND_API_KEY=test to force test mode locally
RESEND_API_KEY=
FROM_EMAIL=noreply@getbridgeable.com
FROM_NAME=Bridgeable

# Twilio (optional — SMS delivery confirmations)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Internal API key (used by Playwright reporter, healthchecks, automated systems)
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_API_KEY=

# Platform admin seed (optional — creates initial super admin on startup)
PLATFORM_ADMIN_EMAIL=
PLATFORM_ADMIN_PASSWORD=
