# ──────────────────────────────────────────────
# ERP Backend — Environment Variables
# Copy to .env and fill in values
# ──────────────────────────────────────────────

# Database (required)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/erp_db

# Auth (required)
SECRET_KEY=change-me-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (required)
CORS_ORIGINS=["http://localhost:5173"]
CORS_ORIGIN_REGEX=

# Environment identifier (dev | staging | production)
ENVIRONMENT=dev

# Redis (optional — job queue degrades to DB polling without it)
REDIS_URL=redis://localhost:6379

# AI (optional)
ANTHROPIC_API_KEY=

# Stripe billing (optional — only needed if billing is configured)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# QuickBooks Online OAuth (optional — only needed if QBO integration is used)
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=
